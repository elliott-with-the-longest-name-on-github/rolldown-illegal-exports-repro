{
  "name": "rolldown-illegal-exports-repro",
  "private": true,
  "type": "module",
  "description": "Minimal reproduction of rolldown leaking __commonJSMin wrappers as top-level ESM exports",
  "scripts": {
    "build:rolldown": "rolldown -c rolldown.config.js",
    "build:rollup": "rollup -c rollup.config.js",
    "build:all": "pnpm build:rolldown && pnpm build:rollup",
    "verify": "node verify.mjs"
  },
  "dependencies": {
    "@vercel/sandbox": "1.10.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "rolldown": "1.0.0",
    "rollup": "^4.62.2"
  }
}
